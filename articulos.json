    <script>
        // Motor editorial: carga artículos desde articulos.json
        async function cargarArticulos() {
            const grid = document.getElementById('articulos-grid');
            try {
                const respuesta = await fetch('articulos.json');
                const datos = await respuesta.json();
                const articulos = datos.articulos || datos;
                
                // Ordenar por fecha (más recientes primero) y tomar los 3 primeros
                articulos.sort((a, b) => new Date(b.fecha) - new Date(a.fecha));
                const recientes = articulos.slice(0, 3);
                
                grid.innerHTML = recientes.map(art => {
                    const extracto = art.extracto || (art.contenido ? art.contenido.substring(0, 180) + '...' : '');
                    const fecha = art.fecha ? formatearFecha(art.fecha) : '';
                    return `
                        <article class="articulo-card" onclick="window.location.href='${art.url || '#'}'">
                            <div class="articulo-imagen">
                                ${art.imagen ? `<img src="${art.imagen}" alt="${art.titulo}" loading="lazy">` : `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:var(--fuente-titulos);font-size:1.1rem;color:var(--color-texto-secundario);font-style:italic;">${art.titulo}</div>`}
                            </div>
                            <div class="articulo-contenido">
                                <div class="articulo-categoria">${art.categoria}</div>
                                <h2 class="articulo-titulo">${art.titulo}</h2>
                                <p class="articulo-extracto">${extracto}</p>
                                <div class="articulo-meta">
                                    <span class="articulo-autor">${art.autor}</span>
                                    <span class="articulo-fecha">${fecha}</span>
                                </div>
                            </div>
                        </article>
                    `;
                }).join('');
            } catch (error) {
                console.error('Error cargando artículos:', error);
                grid.innerHTML = '<p style="text-align:center;color:var(--color-texto-secundario);">No se pudieron cargar los artículos.</p>';
            }
        }

        function formatearFecha(fechaStr) {
            try {
                const fecha = new Date(fechaStr);
                const meses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
                return `${meses[fecha.getMonth()]} ${fecha.getFullYear()}`;
            } catch { return fechaStr; }
        }

        document.addEventListener('DOMContentLoaded', cargarArticulos);
    </script>

